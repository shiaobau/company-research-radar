{
  "version": "1.0.0",
  "description": "歷史時點回測設定。所有評分只使用 observation_date 當日或之前已公開的資料；任一核心維度缺失時不產生總分。",
  "cohort": {
    "templates": "all",
    "companies_per_template": 10,
    "selection": "evenly_spaced_by_ticker",
    "minimum_listing_days": 420
  },
  "timeline": {
    "months": 12,
    "observation_day": 15,
    "forward_return_days": [20, 60, 120],
    "event_lookback_days": 90
  },
  "presets": {
    "full_six_2026_h1": {
      "description": "Three point-in-time observations with a complete 90-day governance and violation lookback window.",
      "observation_dates": ["2026-04-20", "2026-05-20", "2026-06-19"],
      "forward_return_days": [20],
      "event_lookback_days": 90
    }
  },
  "event_classification": {
    "positive_patterns": ["取得訂單", "簽訂合約", "策略合作", "新產品", "量產", "啟用", "獲准", "核准", "收購", "併購"],
    "note": "僅把未被風險分類器標記為負向或待閱讀的公告，且命中此清單者計為正向催化；模式本身不使用產業專屬字詞。"
  },
  "sources": {
    "mops_history": {
      "enabled": true,
      "years": 2,
      "max_events": 160,
      "detail_limit": 0
    },
    "mops_monthly_revenue": {
      "enabled": true,
      "publication_lag_days": 12
    },
    "mops_financial_statements": {
      "enabled": true,
      "publication_lag_days": 50
    },
    "finmind_historical_fallback": {
      "enabled": true,
      "provider": "FinMind",
      "source_type": "third_party_structured_public_data",
      "base_url": "https://api.finmindtrade.com/api/v4/data",
      "no_token_request_budget": 270,
      "datasets": {
        "revenue": "TaiwanStockMonthRevenue",
        "income": "TaiwanStockFinancialStatements",
        "balance": "TaiwanStockBalanceSheet"
      },
      "note": "Used only when the dated MOPS historical form cannot be collected. Raw responses retain their provider and URL. It does not replace the dated governance requirement."
    },
    "historical_prices": {
      "enabled": true,
      "lookback_trading_days": 260
    },
    "historical_governance": {
      "enabled": true,
      "require_dated_source": true,
      "monthly_holdings_api": "https://mops.twse.com.tw/mops/api/query6_1",
      "monthly_holdings_release_lag_days": 15,
      "transfer_redirect_api": "https://mops.twse.com.tw/mops/api/redirectToOld",
      "transfer_result_api": "https://mopsov.twse.com.tw/mops/web/ajax_t56sb21",
      "transfer_lookback_days": 90,
      "violation_lookback_days": 90,
      "violation_sources": {
        "TWSE": "https://openapi.twse.com.tw/v1/opendata/t187ap23_L",
        "TPEx": "https://www.tpex.org.tw/openapi/v1/mopsfin_t187ap23_O"
      }
    }
  },
  "scoring": {
    "require_all_six_core_dimensions": true,
    "industry_adjustment": false,
    "use_current_scoring_rules": true
  }
}
